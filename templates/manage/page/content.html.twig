<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page_title|default('Managing') }}</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f6f7fb;
            color: #1f2937;
        }
        .page-shell {
            max-width: 1200px;
            margin: 0 auto;
            padding: 24px;
        }
        .page-header {
            margin-bottom: 24px;
        }
        .page-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(15, 23, 42, 0.08);
            padding: 24px;
        }
        .page-title {
            margin: 0;
            font-size: 2rem;
        }
        .page-subtitle {
            margin: 8px 0 0;
            color: #6b7280;
        }
    </style>
</head>
<body>
<main class="page-shell">
    <header class="page-header">
        <h1 class="page-title">{{ page_title|default('Managing') }}</h1>
        {% if content_title is defined %}
            <p class="page-subtitle">{{ content_title }}</p>
        {% endif %}
    </header>
    <section class="page-card">
        {{ content|raw }}
    </section>
</main>
</body>
</html>
