{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}{{ page_title|default('Managing') }}{% endblock %}

{% block content_title %}
    {% if content_title is defined and content_title is not empty %}
        {{ content_title }}
    {% elseif page_title is defined and page_title is not empty %}
        {{ page_title }}
    {% endif %}
{% endblock %}

{% block main %}
    {% if content is defined and content is not empty %}
        {{ content|raw }}
    {% endif %}
{% endblock %}
