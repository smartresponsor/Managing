<table class="table datagrid">
    <thead><tr><th>Component</th><th>Resource</th><th>Label</th><th>Entity</th><th>Mode</th><th>Resource path</th><th>Enabled</th><th>Open</th><th>Inspect</th></tr></thead>
    <tbody>
    {% for row in rows %}
        {% set resource = row.resource %}
        <tr>
            <td><code>{{ resource.componentKey }}</code></td>
            <td><code>{{ resource.resourceKey }}</code></td>
            <td>{{ resource.label }}</td>
            <td><code>{{ resource.entityClass }}</code></td>
            <td><code>{{ resource.mode }}</code></td>
            <td>{% if resource.resourcePath %}<code>{{ resource.resourcePath }}</code>{% else %}<span class="text-muted">n/a</span>{% endif %}</td>
            <td>{{ resource.enabled ? 'yes' : 'no' }}</td>
            <td>
                <a class="btn btn-sm btn-primary" href="{{ row.indexUrl }}">Open</a>
            </td>
            <td><a class="btn btn-sm btn-secondary" href="{{ row.detailUrl }}">Details</a></td>
        </tr>
    {% else %}
        <tr><td colspan="9">No Manage CRUD resources registered yet.</td></tr>
    {% endfor %}
    </tbody>
</table>
