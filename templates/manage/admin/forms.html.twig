<table class="table datagrid">
    <thead>
    <tr>
        <th>Component</th>
        <th>Form</th>
        <th>Label</th>
        <th>Form type</th>
        <th>Resource</th>
        <th>Mode</th>
        <th>Surface</th>
        <th>Enabled</th>
        <th>Description</th>
        <th>Inspect</th>
    </tr>
    </thead>
    <tbody>
    {% for row in rows %}
        {% set form = row.form %}
        <tr>
            <td><code>{{ form.componentKey }}</code></td>
            <td><code>{{ form.formKey }}</code></td>
            <td>{{ form.label }}</td>
            <td><code>{{ form.formTypeClass }}</code></td>
            <td>{% if form.resourceKey %}<code>{{ form.resourceKey }}</code>{% else %}<span class="text-muted">n/a</span>{% endif %}</td>
            <td><code>{{ form.mode }}</code></td>
            <td><code>{{ form.surface }}</code></td>
            <td>{{ form.enabled ? 'yes' : 'no' }}</td>
            <td>{{ form.description ?? '' }}</td>
            <td><a class="btn btn-sm btn-primary" href="{{ row.detailUrl }}">details</a></td>
        </tr>
    {% else %}
        <tr><td colspan="10">No Manage form contributions registered yet.</td></tr>
    {% endfor %}
    </tbody>
</table>
