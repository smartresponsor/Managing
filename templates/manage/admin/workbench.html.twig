<div class="content-panel">
    <div class="content-panel-body">
        <p>Consolidated Manage contribution index for the EasyAdmin-native <code>/manage</code> workbench.</p>

        <div class="row">
            <div class="col-md-2"><div class="card"><div class="card-body"><strong>{{ index.totals.components }}</strong><br>Components</div></div></div>
            <div class="col-md-2"><div class="card"><div class="card-body"><strong>{{ index.totals.resources }}</strong><br>Resources</div></div></div>
            <div class="col-md-2"><div class="card"><div class="card-body"><strong>{{ index.totals.routes }}</strong><br>Routes</div></div></div>
            <div class="col-md-2"><div class="card"><div class="card-body"><strong>{{ index.totals.forms }}</strong><br>Forms</div></div></div>
            <div class="col-md-2"><div class="card"><div class="card-body"><strong>{{ index.totals.relations }}</strong><br>Relations</div></div></div>
            <div class="col-md-2"><div class="card"><div class="card-body"><strong>{{ index.totals.probes }}</strong><br>Probes</div></div></div>
        </div>

        <table class="table datagrid mt-4">
            <thead>
            <tr>
                <th>Component</th>
                <th>Resources</th>
                <th>Routes</th>
                <th>Forms</th>
                <th>Relations</th>
                <th>Probes</th>
                <th>Readiness notes</th>
                <th>Inspect</th>
            </tr>
            </thead>
            <tbody>
            {% for row in index.components %}
                {% set component = row.component %}
                {% set componentKey = component ? component.key : 'unregistered' %}
                <tr>
                    <td>
                        <code>{{ componentKey }}</code><br>
                        <span class="text-muted">{{ component ? component.label : 'No component definition registered' }}</span>
                    </td>
                    <td>{{ row.resources|length }}</td>
                    <td>{{ row.routes|length }}</td>
                    <td>{{ row.forms|length }}</td>
                    <td>{{ row.relations|length }}</td>
                    <td>{{ row.probes|length }}</td>
                    <td>
                        {% if row.readiness.resourcesWithoutActions == 0 and row.readiness.routesWithoutUrls == 0 and row.readiness.formsWithMissingTypes == 0 and row.readiness.relationsWithMissingResources == 0 %}
                            <span class="badge badge-success">ready</span>
                        {% else %}
                            {% if row.readiness.resourcesWithoutActions > 0 %}<span class="badge badge-warning">{{ row.readiness.resourcesWithoutActions }} resources without actions</span>{% endif %}
                            {% if row.readiness.routesWithoutUrls > 0 %}<span class="badge badge-warning">{{ row.readiness.routesWithoutUrls }} routes without URL</span>{% endif %}
                            {% if row.readiness.formsWithMissingTypes > 0 %}<span class="badge badge-warning">{{ row.readiness.formsWithMissingTypes }} forms missing type</span>{% endif %}
                            {% if row.readiness.relationsWithMissingResources > 0 %}<span class="badge badge-warning">{{ row.readiness.relationsWithMissingResources }} relations missing resources</span>{% endif %}
                        {% endif %}
                    </td>
                    <td>
                        {% if component %}
                            <a class="btn btn-sm btn-secondary" href="{{ path('manage_dashboard_components_detail', {componentKey: component.key}) }}">Details</a>
                        {% else %}
                            <span class="text-muted">n/a</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8">No Manage workbench contributions registered yet.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
