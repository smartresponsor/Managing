<p><a href="{{ path('manage_components') }}">← Back to components</a></p>

<div class="content-panel">
    <h2>{{ component.label }}</h2>
    <p><code>{{ component.key }}</code></p>
    {% if component.description %}<p>{{ component.description }}</p>{% endif %}
</div>

<h3>Resources</h3>
<table class="table datagrid">
    <thead><tr><th>Key</th><th>Label</th><th>Entity</th><th>Mode</th><th>Index</th><th>Details</th><th>Actions</th></tr></thead>
    <tbody>
    {% for row in resourceRows %}
        {% set resource = row.resource %}
        <tr>
            <td><code>{{ resource.resourceKey }}</code></td>
            <td>{{ resource.label }}</td>
            <td><code>{{ resource.entityClass }}</code></td>
            <td><code>{{ resource.mode }}</code></td>
            <td><a class="btn btn-sm btn-primary" href="{{ path('manage_resource_index', {componentKey: resource.componentKey, resourceKey: resource.resourceKey}) }}">Open</a></td>
            <td><a class="btn btn-sm btn-secondary" href="{{ path('manage_resource_detail', {componentKey: resource.componentKey, resourceKey: resource.resourceKey}) }}">Details</a></td>
            <td>
                {% for action, url in row.actions %}
                    <a class="btn btn-sm btn-secondary" href="{{ url }}">{{ action }}</a>
                {% else %}
                    <span class="text-muted">No generated admin action</span>
                {% endfor %}
            </td>
        </tr>
    {% else %}
        <tr><td colspan="7">No resources.</td></tr>
    {% endfor %}
    </tbody>
</table>
