{% set form = form %}

<div class="content-panel">
    <h2>{{ form.label }}</h2>

    <table class="table">
        <tbody>
        <tr><th>Component</th><td><code>{{ form.componentKey }}</code></td></tr>
        <tr><th>Form key</th><td><code>{{ form.formKey }}</code></td></tr>
        <tr><th>Form type</th><td><code>{{ form.formTypeClass }}</code></td></tr>
        <tr><th>Form type exists</th><td>{{ formTypeExists ? 'yes' : 'no' }}</td></tr>
        <tr><th>Resource key</th><td>{% if form.resourceKey %}<code>{{ form.resourceKey }}</code>{% else %}<span class="text-muted">n/a</span>{% endif %}</td></tr>
        <tr><th>Mode</th><td><code>{{ form.mode }}</code></td></tr>
        <tr><th>Surface</th><td><code>{{ form.surface }}</code></td></tr>
        <tr><th>Menu group</th><td>{{ form.menuGroup ?? 'n/a' }}</td></tr>
        <tr><th>Enabled</th><td>{{ form.enabled ? 'yes' : 'no' }}</td></tr>
        <tr><th>Description</th><td>{{ form.description ?? 'n/a' }}</td></tr>
        </tbody>
    </table>

    <h3>Related resource</h3>
    {% if resource %}
        <table class="table">
            <tbody>
            <tr><th>Resource</th><td><code>{{ resource.componentKey }}/{{ resource.resourceKey }}</code></td></tr>
            <tr><th>Label</th><td>{{ resource.label }}</td></tr>
            <tr><th>Entity</th><td><code>{{ resource.entityClass }}</code></td></tr>
            <tr><th>Mode</th><td><code>{{ resource.mode }}</code></td></tr>
            </tbody>
        </table>

        {% if resourceActions is not empty %}
            <p>
                {% for action, href in resourceActions %}
                    <a class="btn btn-sm btn-secondary" href="{{ href }}">{{ action }}</a>
                {% endfor %}
            </p>
        {% endif %}
    {% else %}
        <p class="text-muted">No related resource is registered for this form.</p>
    {% endif %}

    <p><a class="btn btn-secondary" href="{{ path('manage_forms') }}">Back to forms</a></p>
</div>
