<table class="table datagrid">
    <thead><tr><th>Component</th><th>Probe</th><th>Label</th><th>Description</th><th>Enabled</th><th>Inspect</th><th>Action</th></tr></thead>
    <tbody>
    {% for row in rows %}
        {% set probe = row.probe %}
        <tr>
            <td><code>{{ probe.componentKey }}</code></td>
            <td><code>{{ probe.probeKey }}</code></td>
            <td>{{ probe.label }}</td>
            <td>{{ probe.description ?? '' }}</td>
            <td>{{ probe.enabled ? 'yes' : 'no' }}</td>
            <td><a class="btn btn-sm btn-primary" href="{{ row.detailUrl }}">details</a></td>
            <td><a class="btn btn-sm btn-secondary" href="{{ row.runUrl }}">Run</a></td>
        </tr>
    {% else %}
        <tr><td colspan="7">No Manage probes registered yet.</td></tr>
    {% endfor %}
    </tbody>
</table>
