<div class="content-panel">
    <div class="content-panel-body">
        <p><a class="btn btn-secondary" href="{{ path('manage_probes') }}">Back to probes</a></p>

        <table class="table datagrid">
            <tbody>
                <tr><th>Component</th><td><code>{{ probe.componentKey }}</code></td></tr>
                <tr><th>Probe</th><td><code>{{ probe.probeKey }}</code></td></tr>
                <tr><th>Label</th><td>{{ probe.label }}</td></tr>
                <tr><th>Status</th><td><span class="badge badge-{{ result.passed ? 'success' : (result.status == 'failed' ? 'danger' : 'secondary') }}">{{ result.status }}</span></td></tr>
            </tbody>
        </table>

        <h2>Messages</h2>
        <ul>
            {% for message in result.messages %}
                <li>{{ message }}</li>
            {% else %}
                <li>No messages returned.</li>
            {% endfor %}
        </ul>
    </div>
</div>
