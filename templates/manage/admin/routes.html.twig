<table class="table datagrid">
    <thead><tr><th>Component</th><th>Route</th><th>Label</th><th>Kind</th><th>Menu group</th><th>Enabled</th><th>Open</th><th>Inspect</th></tr></thead>
    <tbody>
    {% for row in rows %}
        {% set route = row.route %}
        <tr>
            <td><code>{{ route.componentKey }}</code></td>
            <td><code>{{ route.routeName }}</code></td>
            <td>{{ route.label }}</td>
            <td><code>{{ route.kind }}</code></td>
            <td>{{ route.menuGroup ?? '' }}</td>
            <td>{{ route.enabled ? 'yes' : 'no' }}</td>
            <td>
                {% if row.url %}
                    <a class="btn btn-sm btn-secondary" href="{{ row.url }}">open</a>
                {% else %}
                    <span class="text-muted">not routable without parameters</span>
                {% endif %}
            </td>
            <td><a class="btn btn-sm btn-primary" href="{{ row.detailUrl }}">details</a></td>
        </tr>
    {% else %}
        <tr><td colspan="8">No Manage routes registered yet.</td></tr>
    {% endfor %}
    </tbody>
</table>
