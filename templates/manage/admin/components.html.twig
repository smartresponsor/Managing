<table class="table datagrid">
    <thead><tr><th>Key</th><th>Label</th><th>Description</th><th>Inspect</th></tr></thead>
    <tbody>
    {% for component in components %}
        <tr>
            <td><code>{{ component.key }}</code></td>
            <td>{{ component.label }}</td>
            <td>{{ component.description ?? '' }}</td>
            <td><a class="btn btn-sm btn-secondary" href="{{ path('manage_component_detail', {componentKey: component.key}) }}">Details</a></td>
        </tr>
    {% else %}
        <tr><td colspan="4">No Manage component contributions registered yet.</td></tr>
    {% endfor %}
    </tbody>
</table>
