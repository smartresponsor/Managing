<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Managing{% endblock %}</title>
    <style>
        :root { color-scheme: light; }
        body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, sans-serif; background: #f6f7f9; color: #111827; }
        .manage-shell { min-height: 100vh; display: grid; grid-template-rows: auto 1fr auto; }
        .manage-header, .manage-footer { background: #fff; border-bottom: 1px solid #e5e7eb; }
        .manage-footer { border-top: 1px solid #e5e7eb; border-bottom: 0; }
        .manage-header-inner, .manage-footer-inner, .manage-main { max-width: 1440px; margin: 0 auto; padding: 16px; }
        .manage-header-inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
        .manage-brand { text-decoration: none; color: inherit; font-weight: 800; font-size: 18px; }
        .manage-subtitle { font-size: 12px; color: #6b7280; }
        .manage-nav { display: flex; flex-wrap: wrap; gap: 8px; }
        .manage-nav a { text-decoration: none; color: #111827; background: #f8fafc; border: 1px solid #d1d5db; border-radius: 999px; padding: 8px 12px; font-size: 13px; }
        .manage-main { width: 100%; box-sizing: border-box; }
        .manage-panel { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04); }
        .manage-title { margin: 0 0 8px; font-size: 28px; line-height: 1.2; }
        .manage-lead { margin: 0 0 18px; color: #4b5563; }
    </style>
</head>
<body>
<div class="manage-shell">
    <header class="manage-header">
        <div class="manage-header-inner">
            <div>
                <a class="manage-brand" href="{{ path('manage_dashboard') }}">Managing</a>
                <div class="manage-subtitle">EasyAdmin-backed admin surface</div>
            </div>
            <nav class="manage-nav" aria-label="Managing navigation">
                <a href="{{ path('manage_dashboard') }}">Dashboard</a>
                <a href="{{ path('manage_dashboard_components_index') }}">Components</a>
                <a href="{{ path('manage_resources') }}">Resources</a>
                <a href="{{ path('manage_routes') }}">Routes</a>
                <a href="{{ path('manage_forms') }}">Forms</a>
                <a href="{{ path('manage_relations') }}">Relations</a>
                <a href="{{ path('manage_probes') }}">Probes</a>
                <a href="{{ path('manage_workbench') }}">Workbench</a>
                <a href="{{ path('manage_status') }}">Status</a>
                <a href="{{ path('manage_security') }}">Security</a>
            </nav>
        </div>
    </header>

    <main class="manage-main">
        {% block body %}{% endblock %}
    </main>

    <footer class="manage-footer">
        <div class="manage-footer-inner">
            {% block footer %}
                <small>Managing component shell</small>
            {% endblock %}
        </div>
    </footer>
</div>
</body>
</html>
