<table class="table datagrid">
    <thead>
    <tr>
        <th>Component</th>
        <th>Relation</th>
        <th>Label</th>
        <th>Source</th>
        <th>Target</th>
        <th>Kind</th>
        <th>Fields</th>
        <th>Surface</th>
        <th>Enabled</th>
        <th>Description</th>
        <th>Detail</th>
    </tr>
    </thead>
    <tbody>
    {% for relation in relations %}
        <tr>
            <td><code>{{ relation.componentKey }}</code></td>
            <td><code>{{ relation.relationKey }}</code></td>
            <td>{{ relation.label }}</td>
            <td><code>{{ relation.sourceResourceKey }}</code></td>
            <td><code>{{ relation.targetResourceKey }}</code></td>
            <td><code>{{ relation.kind }}</code></td>
            <td>
                {% if relation.sourceField or relation.targetField %}
                    <code>{{ relation.sourceField ?? 'n/a' }} → {{ relation.targetField ?? 'n/a' }}</code>
                {% else %}
                    <span class="text-muted">n/a</span>
                {% endif %}
            </td>
            <td><code>{{ relation.surface }}</code></td>
            <td>{{ relation.enabled ? 'yes' : 'no' }}</td>
            <td>{{ relation.description ?? '' }}</td>
            <td><a class="btn btn-sm btn-secondary" href="{{ path('manage_relation_detail', {componentKey: relation.componentKey, relationKey: relation.relationKey}) }}">Open</a></td>
        </tr>
    {% else %}
        <tr><td colspan="11">No Manage relation contributions registered yet.</td></tr>
    {% endfor %}
    </tbody>
</table>
