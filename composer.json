{
  "name": "smart-responsor/managing",
  "description": "Smart Responsor Managing component: EasyAdmin-based management console and ecosystem workbench.",
  "type": "symfony-bundle",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "doctrine/doctrine-bundle": "^3.0",
    "doctrine/orm": "^3.3",
    "easycorp/easyadmin-bundle": "^5.0",
    "symfony/config": "^8.0",
    "symfony/dependency-injection": "^8.0",
    "symfony/form": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/routing": "^8.0",
    "symfony/ux-live-component": "^3.0",
    "symfony/ux-turbo": "^3.0",
    "symfony/yaml": "^8.0",
    "twig/html-extra": "^3.24"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.65",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.0",
    "symfony/browser-kit": "^8.0",
    "symfony/css-selector": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\Managing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Managing\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  }
}
